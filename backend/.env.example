# ── PRODUCCIÓN: cambiar todos los valores marcados con (!) ──────────────────
SECRET_KEY=django-insecure-change-this-in-production   # (!) generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False                                             # (!) nunca True en producción
ALLOWED_HOSTS=tu-dominio.com                           # (!) dominio real

# URL del panel de administración — cambiar a ruta no predecible en producción
DJANGO_ADMIN_PATH=cruzimex-admin-cx7k/                # (!) cambiar a slug aleatorio

# PostgreSQL DW — usar usuario con permisos mínimos (solo SELECT), no postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dw_cruzimex
DB_USER=dw_readonly                                    # (!) no usar postgres (superusuario)
DB_PASSWORD=your_password
